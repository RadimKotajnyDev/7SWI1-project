{
  "ReverseProxy": {
    "Routes": {
      "auth-public": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/auth/{login|register|refresh}"
        }
      },
      "auth-authenticated": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/api/auth/logout"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://auth-service"
          }
        }
      }
    }
  }
}