{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Routing": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/auth/{**remainder}"
        }
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "Default",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/user/{**remainder}"
        }
      },
      "fridge-route": {
        "ClusterId": "shared-fridge-cluster",
        "AuthorizationPolicy": "Default",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/fridge/{**remainder}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://auth-service"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://user-service"
          }
        }
      },
      "shared-fridge-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://shared-fridge-service"
          }
        }
      }
    }
  }
}