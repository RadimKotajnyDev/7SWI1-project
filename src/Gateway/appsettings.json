{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-public": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/auth/{login|refresh|health|alive}"
        }
      },
      "auth-health": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/auth/health"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "auth-authenticated": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Default",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/auth/{logout|register}"
        }
      },
      "user-authenticated": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "Default",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        }
      },
      "user-health": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "Anonymous",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/user/health"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "shared-fridge-authenticated": {
        "ClusterId": "shared-fridge-cluster",
        "AuthorizationPolicy": "Default",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/fridge/{**catch-all}"
        }
      },
      "shared-fridge-health": {
        "ClusterId": "shared-fridge-cluster",
        "AuthorizationPolicy": "Anonymous",
        "CorsPolicy": "AllowAll",
        "Match": {
          "Path": "/api/fridge/health"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://auth-service"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://user-service"
          }
        }
      },
      "shared-fridge-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://shared-fridge-service"
          }
        }
      }
    }
  }
}